    {
      "name": "Auth",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Login successful\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const json = pm.response.json();\r",
                  "\r",
                  "// 🔑 token location\r",
                  "const token = json?.data?.token;\r",
                  "\r",
                  "if (!token) {\r",
                  "    throw new Error(\"Token not found in response\");\r",
                  "}\r",
                  "\r",
                  "// 🎯 detect role automatically\r",
                  "const role = json?.data?.user?.role;\r",
                  "\r",
                  "if (role === \"admin\") {\r",
                  "    pm.environment.set(\"admin_token\", token);\r",
                  "    pm.globals.set(\"admin_token\", token);\r",
                  "    console.log(\"Admin token saved:\", token);\r",
                  "} else {\r",
                  "    pm.environment.set(\"student_token\", token);\r",
                  "    pm.globals.set(\"student_token\", token);\r",
                  "    console.log(\"Student token saved:\", token);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
